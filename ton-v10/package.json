{
  "name": "adoptgold-rwa-ton-v10",
  "version": "1.0.2",
  "private": true,
  "description": "AdoptGold RWA TON V10 collection workspace",
  "license": "UNLICENSED",
  "scripts": {
    "build": "blueprint build",
    "build:item": "blueprint build V10NftItem",
    "build:collection": "blueprint build V10NftCollection",
    "deploy:mainnet": "blueprint run deployV10Collection --mainnet",
    "deploy:testnet": "blueprint run deployV10Collection --testnet",
    "get:mainnet": "blueprint run getV10CollectionData --mainnet",
    "get:testnet": "blueprint run getV10CollectionData --testnet",
    "mint:testnet": "blueprint run testV10PublicMint --testnet",
    "preflight": "bash ./scripts/preflight-check.sh",
    "check:imports": "bash ./scripts/check-v10-imports.sh",
    "check:metadata": "bash ./scripts/check-v10-metadata.sh"
  },
  "dependencies": {
    "@tact-lang/compiler": "^1.6.5",
    "@ton/blueprint": "^0.22.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.2.0",
    "@ton/ton": "^16.2.2",
    "dotenv": "^16.5.0",
    "ton": "^13.9.0",
    "ton-core": "^0.53.0",
    "ts-node": "^10.9.2"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
